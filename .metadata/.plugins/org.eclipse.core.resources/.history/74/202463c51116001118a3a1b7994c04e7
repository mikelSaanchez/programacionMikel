package ejercicio2Ficheros;

import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;

public class Granjero {

	private String nombre;
	private int tipoFumigacion;
	private int m2;
	private boolean descuento;

	public void pedirDatos() {
		BufferedReader leer = new BufferedReader(new InputStreamReader(System.in));

		boolean todoOk = false;

		do {
			try {
				System.out.println("Introduce el nombre ");
				nombre = leer.readLine();

				do {
					System.out.println("Añada el tipo de fumugacion(1-4): ");
					tipoFumigacion = Integer.parseInt(leer.readLine());
				} while (tipoFumigacion < 1 || tipoFumigacion > 4);

				System.out.println("Añada los metros cuadrados de la parcela: ");
				m2 = Integer.parseInt(leer.readLine());

				todoOk = true;
			} catch (NumberFormatException | IOException e) {
				e.printStackTrace();
			}
		} while (!todoOk);

		if (m2 > 10000) {
			descuento = true;
		}

	}

}
