package pruebaFicheros;

import java.io.BufferedReader;
import java.io.File;
import java.io.FileWriter;
import java.io.IOException;
import java.io.InputStreamReader;
import java.io.PrintWriter;

public class principal {

	public static void main(String[] args) throws IOException {
		BufferedReader leer = new BufferedReader(new InputStreamReader(System.in));
	
		System.out.println("Añada su nombre:");
		String nombre = leer.readLine();
		System.out.println("Añada su edad:");
		int edad =Integer.parseInt(leer.readLine());
		System.out.println("Añada su Ciudad:");
		String ciudad = leer.readLine();
		File f = new File ("C:\\Users\\alumnofp\\Desktop\\Programacion\\pruebaFicheros","prueba.txt");
		FileWriter fw = new FileWriter(f);
		PrintWriter pw = new PrintWriter(fw);
		pw.print(nombre+ " - "+edad + " - "+ ciudad);
		pw.flush();
		fw.close();
		pw.close();
	
	}

}
