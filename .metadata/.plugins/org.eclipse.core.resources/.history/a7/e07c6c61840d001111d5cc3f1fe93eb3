package ejercicio16Herencia;

import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.util.ArrayList;

public class Deportistas extends Personas {
	private String categoria;
	private String deporte;

	public void pedirDatos(ArrayList<Deportistas> deportistas) throws IOException {
		BufferedReader leer = new BufferedReader(new InputStreamReader(System.in));
		super.pedirDatos(deportistas);

		System.out.println("Introduce  la categoria(amateur o profesional):");
		categoria = leer.readLine();

		System.out.println("Introduce  el deporte:");
		deporte = leer.readLine();

	}

	public void mostrarDatos() {
		super.mostrarDatos();
		System.out.println("----------");
		System.out.println("Deporte" + this.categoria);
		System.out.println("Categoria" + this.deporte);

	}

}
