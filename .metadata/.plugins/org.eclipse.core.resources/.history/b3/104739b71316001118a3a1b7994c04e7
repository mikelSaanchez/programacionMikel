package ejercicio2Ficheros;

import java.io.BufferedReader;
import java.io.File;
import java.io.FileReader;
import java.io.IOException;
import java.io.InputStreamReader;

public class Principal {

	public static void main(String[] args) throws IOException {

		BufferedReader leer = new BufferedReader(new InputStreamReader(System.in));

		boolean salir = false;
		do {
			System.out.println("\t=== Gestion de Plagas ===");
			System.out.println("1. Opcion 1");
			System.out.println("2. Opcion 2:");
			System.out.println("3. Salir.");
			System.out.print("¿Qué desea consultar?: ");

			int opcion = -1;
			boolean datosOK = false;
			while (!datosOK) {
				try {
					opcion = Integer.parseInt(leer.readLine());
					datosOK = true;
				} catch (NumberFormatException | IOException e) {
					System.err.println("Solo puedes introducir números");
				}
			}

			switch (opcion) {
			case 1:
				opcion1();
				break;
			case 2:
				opcion2();
				break;
			case 3:
				System.out.println("¡Saliendo!");
				salir = true;
				break;
			default:
				System.out.println("Opción no válida");
			}
		} while (!salir);

	}

	private static void opcion1() {

		Granjero grangero = new Granjero();
		grangero.pedirDatos();
		grangero.guardar();
		
	}
	
	private static void opcion2() throws IOException {
		File f = new File("./grangeros.txt");
		if (f.exists()) {
			FileReader fr = new FileReader(f);
			BufferedReader br = new BufferedReader(fr);

			Granjero a = new Granjero();

			String linea = br.readLine();

			while (linea != null) {
				String[] v;
				
				linea = br.readLine();
				v = linea.split(": ");
				a.setNombre(v[1]);

				v = linea.split(": ");
				a.setTipoFumigacion(Integer.parseInt(v[1]));

				v = linea.split(": ");
				a.setM2(Integer.parseInt(v[1]));

				linea = br.readLine();

				br.close();
				fr.close();
			}

		} else {
			System.out.println("El fichero no existe.");
		}
	}

}
